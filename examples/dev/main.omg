extern puts : (fmt: *char) => i32;
extern printf : (fmt: *char, ...) => i32;

struct MyString {
    buffer: *[char];
    length: i32;
}

print_message(msg: *char) => i32 {
    puts(msg);
    return 0;
}

main(argc : i32, argv : [*char]) => i32 {
    msg : *char;
    msg = "hello worlderino";
    print_message(msg);

    printf("argc: %d", argc);
    puts("");

    progname : *char;
    progname = argv[0];

    first_arg : *char;
    first_arg = argv[1];

    printf("Command line: %s %s", progname, first_arg);
    puts("");

    return 69;
}
