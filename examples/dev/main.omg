extern puts : (s: *char) => i32;
extern printf : (s : *char, ...) => i32;

struct Interface {
    do_thing: (s : *char) => i32;
    member_function(self) => void {
        self.do_thing("You called the member function");
    }
}

main(argc : i32, argv : [*char]) => i32 {
    iface : Interface;
    iface.do_thing = puts;
    iface.do_thing("HELLO WORLD");
    iface.do_thing("");
    iface.member_function();
    ptr : *Interface;
    ptr = &iface;
    (*ptr).member_function();
    ptr.member_function();

    a := 5;
    b := 10;
    c := a + b;
    printf("%d + %d = %d", a, b, c);
    puts("");

    # this is a single line comment
    a = 10;
    b = 3; # this is also a comment
    c = a * b;
    printf("%d * %d = %d", a, b, c);
    puts("");

    ##### this is a
    multine ###
       ##comment #####
    
    return 69;
}
