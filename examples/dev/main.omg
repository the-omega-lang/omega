extern puts : (s: *char) => i32;

struct Interface {
    do_thing: (s : *char) => i32;
    member_function(self) => void {
        puts("You called the member function");
    }
}

main(argc : i32, argv : [*char]) => i32 {
    iface : Interface;
    iface.do_thing = puts;
    iface.do_thing("HELLO WORLD");
    iface.do_thing("");
    iface.member_function();
    ptr : *Interface;
    ptr = &iface;
    (*ptr).member_function();
    ptr.member_function();
    return 69;
}
