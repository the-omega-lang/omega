extern puts : (fmt: *char) => i32;
extern printf : (fmt: *char, ...) => i32;

print_message(msg: *char, msg2: *char) => i32 {
    puts(msg);
    puts(msg2);
    return 0;
}

main(argc : i32, argv : **char) => i32 {
    a : i32;
    a = 69;
    msg : *char;
    msg = "hello worlderino";
    print_message(msg, "abcdef");
    printf("Number: %d", a);
    puts("");
    printf("Argc: %d", argc);
    puts("");


    first_arg : *char;
    first_arg = argv[0];

    return a;
}
