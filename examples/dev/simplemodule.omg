something3(n : i32) => i32 {
    n * 3
}

# Reached from `main` as `simplemodule::Pair::of(...)` -- a static function
# on a struct in another module, resolved through the imported module alias.
struct Pair {
    a: i32;
    b: i32;
    of(a: i32, b: i32) => Pair {
        Pair { a = a; b = b; }
    }
    sum(*self) => i32 {
        self.a + self.b
    }
}

# Reached from `main` as `simplemodule::Status::Ok` /
# `simplemodule::Status::Err { ... }` / `simplemodule::Status::make_err(...)`
# -- enum variants and static functions resolve through an imported module
# alias exactly like a struct's statics do.
enum Status(tag: u8, label: *str) {
    Ok(0, "all good"),
    Err(1, "something failed") { code: i32; };

    make_err(code: i32) => Status {
        Status::Err { code = code; }
    }
}
